{
  "role": "planner",
  "skills": [
    "writing-plans",
    "executing-plans"
  ],
  "model": "claude-sonnet-4-6",
  "workingDirectoryStrategy": "repo",
  "contextBudget": 100000,
  "allowedTools": [
    "read",
    "bash"
  ],
  "env": {},
  "hooks": {
    "PostToolUse": [
      {
        "id": "stop-sentinel-check",
        "command": "node -e \"const fs=require('fs'),p=(process.env.LEGION_SWARM_ROOT||'.')+'/.watchdog/STOP';if(fs.existsSync(p)){process.exit(1);}\"",
        "trigger": "always"
      }
    ]
  }
}